index 86acd08..4879b8c 100644
--- a/torchtitan/models/llama3/model/model.py
+++ b/torchtitan/models/llama3/model/model.py
@@ -22,6 +22,54 @@ from torchtitan.models.attention import (
     get_block_causal_mask_mod_by_seq_lens,
     ScaledDotProductAttentionWrapper,
 )
+from torchtitan.models.llama3.model.lighthouse_selection import (
+    DilatedLighthouseScorer as DLSLocal,
+    DialatedLighthouseNormScorer as DLSNormLocal,
+    DilatedLighthouseGLAScorer as DLSGLALocal,
+    LighthouseLocal as LLocal,
+    DialatedLighthouseNormScorerCP as DLSNormCP,
+    LighthouseCP as LCP,
+)
+
+
+def _build_lighthouse_scorer(model_args, head_dim: int):
+    """Construct a Lighthouse scorer from `model_args.lighthouse_scorer`.
+
+    Returns `(scorer, needs_gate)` where `needs_gate=True` for the GLA scorer
+    (so the caller knows to instantiate a per-token gate projection `wg` and
+    pass `gk` through the forward path).
+    """
+    name = (model_args.lighthouse_scorer or "norm").lower()
+    use_cp = bool(getattr(model_args, "use_lighthouse_cp", False))
+    if use_cp and name != "norm":
+        raise ValueError(
+            f"lighthouse_scorer='{name}' is not supported under context "
+            "parallelism. The CP path was validated only for 'norm'; set "
+            "lighthouse_scorer='norm' or disable use_lighthouse_cp."
+        )
+    common = dict(
+        pooling_factor=model_args.lighthouse_pooling_factor,
+        levels=model_args.lighthouse_num_levels,
+    )
+    if name == "norm":
+        cls = DLSNormCP if use_cp else DLSNormLocal
+        return cls(**common), False
+    if name == "dilated":
+        return DLSLocal(
+            head_dim=head_dim,
+            dilation=getattr(model_args, "dilation", 4),
+            **common,
+        ), False
+    if name == "gla":
+        return DLSGLALocal(
+            head_dim=head_dim,
+            dilation=getattr(model_args, "dilation", 4),
+            **common,
+        ), True
